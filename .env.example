### Magento / Database settings used for local development
### Copy to .env and customize as needed. Do NOT check in .env.

# Magento marketplace credentials (required for composer install)
MAGENTO_PUBLIC_KEY=your_public_key
MAGENTO_PRIVATE_KEY=your_private_key

# Magento version / edition
MAGENTO_EDITION=community
MAGENTO_VERSION=2.4.7

# Web
MAGENTO_BASE_URL=http://localhost:8080/

# Database (docker-compose defaults)
DB_HOST=db
DB_NAME=magento
DB_USER=magento
DB_PASSWORD=magento
DB_ROOT_PASSWORD=magento

# Redis (optional caching/queues)
REDIS_HOST=redis
REDIS_PORT=6379

# Elasticsearch (required by Magento 2.4+)
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# Admin user (change for production)
MAGENTO_ADMIN_USER=admin
MAGENTO_ADMIN_PASSWORD=Admin123!
MAGENTO_ADMIN_EMAIL=admin@example.com
MAGENTO_ADMIN_FIRSTNAME=Admin
MAGENTO_ADMIN_LASTNAME=User

# For CI/ Railway you can set a random key for this, but keep it stable if you want sessions to persist.
MAGENTO_BACKEND_FRONTNAME=admin
